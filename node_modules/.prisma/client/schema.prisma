generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ AUTH ============

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  fullName  String?  @map("full_name") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  profile          Profile?
  userRoles        UserRole[]
  leadsAssigned    Lead[]        @relation("LeadAssignee")
  leadsCreated     Lead[]        @relation("LeadCreator")
  contactsCreated  Contact[]
  projectsAssigned Project[]     @relation("ProjectAssignee")
  projectsCreated  Project[]     @relation("ProjectCreator")
  invoicesCreated  Invoice[]
  expensesCreated  Expense[]
  salesEmployee    Sale[]
  activityLogs     ActivityLog[]

  @@map("users")
}

model Profile {
  id          String    @id @db.VarChar(36)
  fullName    String?   @map("full_name") @db.VarChar(255)
  email       String?   @db.VarChar(255)
  phone       String?   @db.VarChar(50)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(500)
  department  String?   @db.VarChar(100)
  joiningDate DateTime? @map("joining_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

enum AppRole {
  admin
  employee
}

model UserRole {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// ============ CRM: LEADS ============

model Lead {
  id           String    @id @default(uuid()) @db.VarChar(36)
  name         String    @db.VarChar(255)
  company      String?   @db.VarChar(255)
  email        String?   @db.VarChar(255)
  phone        String?   @db.VarChar(50)
  whatsapp     String?   @db.VarChar(50)
  address      String?   @db.Text
  city         String?   @db.VarChar(100)
  state        String?   @db.VarChar(100)
  country      String?   @db.VarChar(100)
  category     String?   @db.VarChar(100)
  source       String?   @db.VarChar(50)
  status       String    @default("interested") @db.VarChar(50)
  priority     String    @default("medium") @db.VarChar(20)
  assignedTo   String?   @map("assigned_to") @db.VarChar(36)
  followUpDate DateTime? @map("follow_up_date") @db.Date
  notes        String?   @db.Text
  createdBy    String?   @map("created_by") @db.VarChar(36)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  assignee User? @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator  User? @relation("LeadCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([assignedTo])
  @@index([createdBy])
  @@map("leads")
}

// ============ CRM: CONTACTS ============

model Contact {
  id          String    @id @default(uuid()) @db.VarChar(36)
  clientName  String    @map("client_name") @db.VarChar(255)
  company     String?   @db.VarChar(255)
  email       String?   @db.VarChar(255)
  phone       String?   @db.VarChar(50)
  whatsapp    String?   @db.VarChar(50)
  website     String?   @db.VarChar(500)
  gst         String?   @db.VarChar(20)
  pan         String?   @db.VarChar(20)
  address     String?   @db.Text
  city        String?   @db.VarChar(100)
  state       String?   @db.VarChar(100)
  country     String?   @db.VarChar(100)
  category    String?   @db.VarChar(100)
  tags        Json?
  notes       String?   @db.Text
  clientSince DateTime? @default(now()) @map("client_since") @db.Date
  createdBy   String?   @map("created_by") @db.VarChar(36)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  creator  User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  projects Project[]
  invoices Invoice[]
  sales    Sale[]

  @@index([createdBy])
  @@map("contacts")
}

// ============ PROJECTS ============

model Project {
  id              String    @id @default(uuid()) @db.VarChar(36)
  name            String    @db.VarChar(255)
  contactId       String?   @map("contact_id") @db.VarChar(36)
  projectType     String?   @map("project_type") @db.VarChar(50)
  status          String    @default("not_started") @db.VarChar(50)
  deadline        DateTime? @db.Date
  assignedTo      String?   @map("assigned_to") @db.VarChar(36)
  budget          Decimal?  @default(0) @db.Decimal(12, 2)
  finalPrice      Decimal?  @default(0) @map("final_price") @db.Decimal(12, 2)
  receivedAmount  Decimal?  @default(0) @map("received_amount") @db.Decimal(12, 2)
  purchaseCost    Decimal?  @default(0) @map("purchase_cost") @db.Decimal(12, 2)
  hostingIncluded Boolean?  @default(false) @map("hosting_included")
  domainIncluded  Boolean?  @default(false) @map("domain_included")
  renewalDate     DateTime? @map("renewal_date") @db.Date
  notes           String?   @db.Text
  createdBy       String?   @map("created_by") @db.VarChar(36)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee User?     @relation("ProjectAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator  User?     @relation("ProjectCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@index([contactId])
  @@index([assignedTo])
  @@index([createdBy])
  @@map("projects")
}

// ============ INVOICES ============

model Invoice {
  id            String    @id @default(uuid()) @db.VarChar(36)
  invoiceNumber String    @unique @map("invoice_number") @db.VarChar(50)
  contactId     String?   @map("contact_id") @db.VarChar(36)
  projectId     String?   @map("project_id") @db.VarChar(36)
  issueDate     DateTime  @default(now()) @map("issue_date") @db.Date
  dueDate       DateTime? @map("due_date") @db.Date
  subtotal      Decimal   @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discount      Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @default(0) @db.Decimal(12, 2)
  status        String    @default("pending") @db.VarChar(50)
  notes         String?   @db.Text
  terms         String?   @db.Text
  createdBy     String?   @map("created_by") @db.VarChar(36)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  contact Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  project Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator User?         @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  items   InvoiceItem[]

  @@index([contactId])
  @@index([projectId])
  @@index([createdBy])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid()) @db.VarChar(36)
  invoiceId   String  @map("invoice_id") @db.VarChar(36)
  description String  @db.VarChar(500)
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  rate        Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ============ EXPENSES ============

model Expense {
  id            String   @id @default(uuid()) @db.VarChar(36)
  title         String   @db.VarChar(255)
  category      String?  @db.VarChar(50)
  vendor        String?  @db.VarChar(255)
  amount        Decimal  @default(0) @db.Decimal(12, 2)
  gst           Decimal? @default(0) @db.Decimal(12, 2)
  expenseDate   DateTime @default(now()) @map("expense_date") @db.Date
  paymentMethod String?  @map("payment_method") @db.VarChar(50)
  paidBy        String?  @map("paid_by") @db.VarChar(255)
  description   String?  @db.Text
  recurring     String?  @db.VarChar(50)
  createdBy     String?  @map("created_by") @db.VarChar(36)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@map("expenses")
}

// ============ SALES ============

model Sale {
  id            String   @id @default(uuid()) @db.VarChar(36)
  productName   String   @map("product_name") @db.VarChar(255)
  category      String?  @db.VarChar(50)
  contactId     String?  @map("contact_id") @db.VarChar(36)
  purchaseCost  Decimal? @default(0) @map("purchase_cost") @db.Decimal(12, 2)
  sellingPrice  Decimal  @default(0) @map("selling_price") @db.Decimal(12, 2)
  quantity      Decimal? @default(1) @db.Decimal(10, 2)
  saleDate      DateTime @default(now()) @map("sale_date") @db.Date
  paymentStatus String?  @default("pending") @map("payment_status") @db.VarChar(50)
  employeeId    String?  @map("employee_id") @db.VarChar(36)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  employee User?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([employeeId])
  @@map("sales")
}

// ============ PRODUCTS ============

model Product {
  id            String   @id @default(uuid()) @db.VarChar(36)
  name          String   @db.VarChar(255)
  category      String?  @db.VarChar(50)
  purchasePrice Decimal? @default(0) @map("purchase_price") @db.Decimal(12, 2)
  sellingPrice  Decimal? @default(0) @map("selling_price") @db.Decimal(12, 2)
  supplier      String?  @db.VarChar(255)
  stock         Int?     @default(0)
  status        String?  @default("active") @db.VarChar(50)
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("products")
}

// ============ HOSTING / DOMAINS ============

// ============ ACTIVITY LOG ============

model ActivityLog {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String?  @map("user_id") @db.VarChar(36)
  action     String   @db.VarChar(255)
  entityType String?  @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(36)
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("activity_logs")
}
